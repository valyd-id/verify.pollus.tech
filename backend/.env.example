APP_NAME="Valyd Verify"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://verify.valyd.net

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=verify_valyd
DB_USERNAME=postgres
DB_PASSWORD=

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

# --- Hosted verification UI ---
VERIFY_HOSTED_BASE_URL=https://verify.valyd.net
VERIFY_DEFAULT_SESSION_TTL=1800
VERIFY_WEBHOOK_QUEUE=default
VERIFY_FACE_MATCH_THRESHOLD=0.95
VERIFY_LIVENESS_THRESHOLD=50
VERIFY_IMAGE_DISK=local

# --- Engines ---
REMOTE_FACE_URL=https://faceonlive-face.pollus.us
REMOTE_FACE_OCR_URL=https://faceonlive-ocr.pollus.us
ZK_VERIFY_API_URL=http://localhost:4000/api/prove
ZK_VERIFY_TIMEOUT=120

# --- Professional license (vc.pollus.tech m2m) ---
VC_BASE_URL=https://vc.pollus.tech
VC_VERIFY_PATH=api/bulk-verify-credential
VC_API_KEY=
VC_TIMEOUT=360

# --- Which Valyd environment this instance talks to ---
# development → idp.pollus.tech | staging → idp.pollus.online | production → idp.valyd.id
# This derives the IdP origin used for BOTH end-user token validation (services.idp)
# and console-login OIDC, so verify always validates tokens against the same IdP that
# issued them. Set this per deployment. (IDP_BASE_URL / VALYD_OIDC_BASE_URL still override.)
VALYD_ENV=development

# --- Developer console: Login with Valyd (OIDC relying-party) ---
# Register a client at the IdP with the redirect_uri below, then fill these.
# Leave VALYD_OIDC_BASE_URL unset to derive it from VALYD_ENV (recommended).
# VALYD_OIDC_BASE_URL=https://idp.pollus.tech
VALYD_OIDC_CLIENT_ID=
VALYD_OIDC_CLIENT_SECRET=
VALYD_OIDC_REDIRECT_URI=https://verify.pollus.tech/login
VALYD_OIDC_SCOPES="openid profile email"
