# "Login with Valyd" (OIDC) — ALL OPTIONAL. Defaults below are production-correct,
# and the redirect URI is derived from the current origin at runtime, so you can
# deploy to production without changing anything here.
#
# Override only if needed:
# VITE_VALYD_IDP_URL=https://idp.pollus.tech
# VITE_VALYD_CLIENT_ID=verify-console
# VITE_VALYD_SCOPES=openid profile email
# VITE_VALYD_AUTHORIZE_PATH=api/auth/oidc/authorize
# VITE_VALYD_REDIRECT_URI=     # leave unset to use {origin}/login automatically
